rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /shops/{id}               { allow read, write: if request.auth != null; }
    match /investors/{id}           { allow read, write: if request.auth != null; }
    match /employees/{id}           { allow read, write: if request.auth != null; }
    match /shop_investors/{id}      { allow read, write: if request.auth != null; }
    match /transactions/{id}        { allow read, write: if request.auth != null; }
    match /settlements/{id}         { allow read, write: if request.auth != null; }
    match /settlement_entries/{id}  { allow read, write: if request.auth != null; }
    // Tombstone markers for cross-device delete propagation (FirebaseSyncRepository.pushDeletions /
    // FirebasePullRepository.pullDeletions). Without this, deletes reach the server but never
    // propagate to other devices and local tombstones never clear.
    match /deletions/{id}           { allow read, write: if request.auth != null; }
  }
}
